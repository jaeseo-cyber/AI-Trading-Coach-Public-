# Streamlit Cloud Secrets 예시
# ⚠ API 키에는 한글 설명(예: "여기에 키 입력")이 아닌 실제 키만 넣으세요.

# --- 옵션 A: Gemini만 ---
GEMINI_API_KEY = "your_gemini_api_key"
GEMINI_MODEL = "gemini-2.5-flash-lite"

# --- 옵션 B: Groq만 (Gemini 한도 문제 시) ---
# LLM_PROVIDER = "groq"
# GROQ_API_KEY = "gsk_..."
# GROQ_MODEL = "llama-3.1-8b-instant"

# --- 옵션 C: Gemini + Groq (권장 — Gemini 실패 시 Groq 자동 전환) ---
# GROQ_API_KEY = "gsk_..."
# GROQ_MODEL = "llama-3.1-8b-instant"
